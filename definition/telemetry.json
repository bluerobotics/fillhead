{
    "main_state": {
        "type": "string",
        "default": "standby",
        "firmware_key": "fillhead_state",
        "help": "Overall fillhead system state",
        "gui_var": "fillhead_main_state_var"
    },
    "injector_state": {
        "type": "int",
        "default": 0,
        "map": {
            "0": "standby",
            "1": "homing",
            "2": "jogging",
            "3": "feeding",
            "4": "motor fault"
        },
        "help": "Current operational state of the injector motors",
        "gui_var": "fillhead_injector_state_var"
    },
    "inj_valve_state": {
        "type": "int",
        "default": 0,
        "map": {
            "0": "not homed",
            "1": "closed",
            "2": "open",
            "3": "halted",
            "4": "moving",
            "5": "homing",
            "6": "jogging",
            "7": "resetting",
            "8": "error"
        },
        "help": "Current state of the injection pinch valve",
        "gui_var": "fillhead_inj_valve_state_var"
    },
    "vac_valve_state": {
        "type": "int",
        "default": 0,
        "map": {
            "0": "not homed",
            "1": "closed",
            "2": "open",
            "3": "halted",
            "4": "moving",
            "5": "homing",
            "6": "jogging",
            "7": "resetting",
            "8": "error"
        },
        "help": "Current state of the vacuum pinch valve",
        "gui_var": "fillhead_vac_valve_state_var"
    },
    "heater_state": {
        "type": "int",
        "default": 0,
        "firmware_key": "h_st",
        "map": {
            "0": "off",
            "1": "active"
        },
        "help": "Heater PID control status",
        "gui_var": "fillhead_heater_state_var"
    },
    "vacuum_state": {
        "type": "int",
        "default": 0,
        "firmware_key": "vac_st",
        "map": {
            "0": "off",
            "1": "pulldown",
            "2": "settling",
            "3": "leak testing",
            "4": "on",
            "5": "ramping",
            "6": "error"
        },
        "help": "Current vacuum system operation state",
        "gui_var": "fillhead_vacuum_state_var"
    },
    "injector_torque": {
        "unit": "%",
        "type": "float",
        "default": 0.0,
        "precision": 1,
        "firmware_key": "inj_t0",
        "help": "Current motor torque percentage for injector (motor 0)",
        "gui_var": "fillhead_injector_torque_var"
    },
    "injector_homed": {
        "type": "int",
        "default": 0,
        "firmware_key": "inj_h_mach",
        "map": {
            "0": "not homed",
            "1": "homed"
        },
        "help": "Indicates if injector has been homed to machine zero",
        "gui_var": "fillhead_injector_homed_var"
    },
    "injection_cumulative_ml": {
        "unit": "ml",
        "type": "float",
        "default": 0.0,
        "precision": 2,
        "firmware_key": "inj_cumulative_ml",
        "help": "Total volume dispensed since last cartridge home",
        "gui_var": "fillhead_injection_cumulative_ml_var"
    },
    "injection_active_ml": {
        "unit": "ml",
        "type": "float",
        "default": 0.0,
        "precision": 2,
        "firmware_key": "inj_active_ml",
        "help": "Volume dispensed in current injection operation",
        "gui_var": "fillhead_injection_active_ml_var"
    },
    "injection_target_ml": {
        "unit": "ml",
        "type": "float",
        "default": 0.0,
        "precision": 2,
        "firmware_key": "inj_tgt_ml",
        "help": "Target volume for current injection operation",
        "gui_var": "fillhead_injection_target_ml_var"
    },
    "motors_enabled": {
        "type": "bool",
        "default": 1,
        "derived_from": ["enabled0", "enabled1"],
        "map": {
            "0": "disabled",
            "1": "enabled"
        },
        "help": "Global motor power enable status (derived from enabled0 AND enabled1)",
        "gui_var": "fillhead_motors_enabled_var"
    },
    "inj_valve_pos": {
        "unit": "mm",
        "type": "float",
        "default": 0.0,
        "precision": 2,
        "help": "Current position of injection valve actuator",
        "gui_var": "fillhead_inj_valve_pos_var"
    },
    "inj_valve_torque": {
        "unit": "%",
        "type": "float",
        "default": 0.0,
        "precision": 1,
        "help": "Current motor torque percentage for injection valve",
        "gui_var": "fillhead_inj_valve_torque_var"
    },
    "inj_valve_homed": {
        "type": "bool",
        "default": 0,
        "map": {
            "0": "not homed",
            "1": "homed"
        },
        "help": "Indicates if injection valve has been homed",
        "gui_var": "fillhead_inj_valve_homed_var"
    },
    "vac_valve_pos": {
        "unit": "mm",
        "type": "float",
        "default": 0.0,
        "precision": 2,
        "help": "Current position of vacuum valve actuator",
        "gui_var": "fillhead_vac_valve_pos_var"
    },
    "vac_valve_motor_torque": {
        "unit": "%",
        "type": "float",
        "default": 0.0,
        "precision": 1,
        "firmware_key": "vac_valve_torque",
        "help": "Current motor torque percentage for vacuum valve",
        "gui_var": "fillhead_vac_valve_motor_torque_var"
    },
    "vac_valve_homed": {
        "type": "bool",
        "default": 0,
        "map": {
            "0": "not homed",
            "1": "homed"
        },
        "help": "Indicates if vacuum valve has been homed",
        "gui_var": "fillhead_vac_valve_homed_var"
    },
    "temp_c": {
        "unit": "C",
        "type": "float",
        "default": 25.0,
        "precision": 1,
        "firmware_key": "h_pv",
        "help": "Current material temperature from thermocouple",
        "gui_var": "fillhead_temp_c_var"
    },
    "heater_setpoint": {
        "unit": "C",
        "type": "float",
        "default": 70.0,
        "precision": 1,
        "firmware_key": "h_sp",
        "help": "Target temperature setpoint for PID controller",
        "gui_var": "fillhead_heater_setpoint_var"
    },
    "vacuum_psig": {
        "unit": "PSIG",
        "type": "float",
        "default": 0.5,
        "precision": 2,
        "firmware_key": "vac_pv",
        "help": "Current vacuum pressure reading",
        "gui_var": "fillhead_vacuum_psig_var"
    },
    "force_load_cell": {
        "unit": "kg",
        "type": "float",
        "default": 0.0,
        "precision": 2,
        "firmware_key": "flc",
        "help": "Force from load cell sensor",
        "gui_var": "fillhead_force_load_cell_var"
    },
    "force_motor_torque": {
        "unit": "kg",
        "type": "float",
        "default": 0.0,
        "precision": 2,
        "firmware_key": "fmt",
        "help": "Force calculated from motor torque",
        "gui_var": "fillhead_force_motor_torque_var"
    },
    "force_limit": {
        "unit": "kg",
        "type": "float",
        "default": 1000.0,
        "precision": 1,
        "firmware_key": "fl",
        "help": "Maximum force limit for current operation",
        "gui_var": "fillhead_force_limit_var"
    },
    "force_source": {
        "type": "string",
        "default": "load_cell",
        "derived_from": ["force_mode"],
        "help": "Source of force reading: load_cell or motor_torque (derived from force_mode)",
        "gui_var": "fillhead_force_source_var"
    },
    "force_adc_raw": {
        "type": "int",
        "default": 0,
        "firmware_key": "far",
        "help": "Raw ADC value from HX711 load cell amplifier (for calibration)",
        "gui_var": "fillhead_force_adc_raw_var"
    },
    "force_mode": {
        "type": "string",
        "default": "load_cell",
        "firmware_key": "fm",
        "help": "Active force sensing mode (load_cell or motor_torque)",
        "gui_var": "fillhead_force_mode_var"
    },
    "joules": {
        "unit": "J",
        "type": "float",
        "default": 0.0,
        "precision": 3,
        "firmware_key": "j",
        "help": "Energy expended during current move (force × distance integrated at 50Hz)",
        "gui_var": "fillhead_joules_var"
    },
    "enabled0": {
        "type": "int",
        "default": 1,
        "map": {
            "0": "disabled",
            "1": "enabled"
        },
        "help": "Power enable status for motor 0",
        "gui_var": "fillhead_enabled0_var"
    },
    "enabled1": {
        "type": "int",
        "default": 1,
        "map": {
            "0": "disabled",
            "1": "enabled"
        },
        "help": "Power enable status for motor 1",
        "gui_var": "fillhead_enabled1_var"
    },
    "current_pos": {
        "unit": "mm",
        "type": "float",
        "default": 0.0,
        "precision": 2,
        "firmware_key": "cp",
        "help": "Current position of press axis",
        "gui_var": "fillhead_current_pos_var"
    },
    "retract_pos": {
        "unit": "mm",
        "type": "float",
        "default": 0.0,
        "precision": 2,
        "firmware_key": "rp",
        "help": "Preset retract position for the press",
        "gui_var": "fillhead_retract_pos_var"
    },
    "target_pos": {
        "unit": "mm",
        "type": "float",
        "default": 0.0,
        "precision": 2,
        "firmware_key": "tp",
        "help": "Target position for current move operation",
        "gui_var": "fillhead_target_pos_var"
    },
    "endpoint": {
        "unit": "mm",
        "type": "float",
        "default": 0.0,
        "precision": 2,
        "firmware_key": "ep",
        "help": "Actual position where last move ended (force trigger or completion)",
        "gui_var": "fillhead_endpoint_var"
    },
    "startpoint": {
        "unit": "mm",
        "type": "float",
        "default": 0.0,
        "precision": 2,
        "firmware_key": "sp",
        "help": "Position where press threshold was crossed (press started)",
        "gui_var": "fillhead_startpoint_var"
    },
    "press_threshold": {
        "unit": "kg",
        "type": "float",
        "default": 2.0,
        "precision": 2,
        "firmware_key": "pt",
        "help": "Force threshold for energy/startpoint recording",
        "gui_var": "fillhead_press_threshold_var"
    },
    "torque_avg": {
        "unit": "%",
        "type": "float",
        "default": 0.0,
        "precision": 1,
        "firmware_key": "ta",
        "help": "Average motor torque percentage",
        "gui_var": "fillhead_torque_avg_var"
    },
    "homed": {
        "type": "int",
        "default": 0,
        "firmware_key": "hm",
        "map": {
            "0": "not homed",
            "1": "homed"
        },
        "help": "Indicates if press has been homed to zero position",
        "gui_var": "fillhead_homed_var"
    },
    "home_sensor_m0": {
        "type": "int",
        "default": 0,
        "firmware_key": "hs0",
        "map": {
            "0": "inactive",
            "1": "active"
        },
        "help": "Motor A (M0) home sensor state (DI7)",
        "gui_var": "fillhead_home_sensor_m0_var"
    },
    "home_sensor_m1": {
        "type": "int",
        "default": 0,
        "firmware_key": "hs1",
        "map": {
            "0": "inactive",
            "1": "active"
        },
        "help": "Motor B (M1) home sensor state (DI6)",
        "gui_var": "fillhead_home_sensor_m1_var"
    },
    "polarity": {
        "type": "string",
        "default": "normal",
        "firmware_key": "pol",
        "help": "Coordinate system polarity (normal or inverted)",
        "gui_var": "fillhead_polarity_var"
    }
}
