    "dump_error_log": {
        "device": "fillhead",
        "target": "device",
        "description": "Dump internal error log buffer for diagnostics.",
        "params": [],
        "returns": ["info", "done", "error"]
    },
    "set_force_mode": {
        "device": "fillhead",
        "target": "device",
        "description": "Sets the force sensing mode (persisted to NVM).",
        "params": [
            { "parameter": "mode", "type": "string", "enum": ["motor_torque", "load_cell"], "help": "motor_torque = use motor torque calculation (no load cell needed), load_cell = use actual load cell sensor" }
        ],
        "returns": ["done", "error"]
    },
    "set_force_offset": {
        "device": "fillhead",
        "target": "device",
        "description": "Set force calibration offset and save to NVM. Routes to load cell or motor torque calibration based on current force mode.",
        "params": [
            { "parameter": "offset", "type": "float", "help": "In load_cell mode: offset in kg. In motor_torque mode: torque% intercept (default 1.04)" }
        ],
        "returns": ["done", "error"]
    },
    "set_force_zero": {
        "device": "fillhead",
        "target": "device",
        "description": "Adjusts the current force calibration offset so the present force reading becomes zero.",
        "params": [],
        "returns": ["info", "done", "error"]
    },
    "set_force_scale": {
        "device": "fillhead",
        "target": "device",
        "description": "Set force sensor scale/linearity factor and save to NVM.",
        "params": [
            { "parameter": "scale", "type": "float", "help": "In load_cell mode: kg per raw ADC unit. In motor_torque mode: torque% per kg slope (default 0.0335)" }
        ],
        "returns": ["done", "error"]
    },
    "set_strain_cal": {
        "device": "fillhead",
        "target": "device",
        "description": "Set machine strain energy compensation coefficients (force vs distance polynomial) and save to NVM.",
        "params": [
            { "parameter": "x4", "type": "float", "unit": "x^4", "help": "Coefficient for x^4 term" },
            { "parameter": "x3", "type": "float", "unit": "x^3", "help": "Coefficient for x^3 term" },
            { "parameter": "x2", "type": "float", "unit": "x^2", "help": "Coefficient for x^2 term" },
            { "parameter": "x1", "type": "float", "unit": "x", "help": "Coefficient for x term" },
            { "parameter": "c", "type": "float", "unit": "C", "help": "Constant term" }
        ],
        "returns": ["done", "error"]
    },
    "set_polarity": {
        "device": "fillhead",
        "target": "device",
        "description": "Sets the coordinate system polarity (normal or inverted) and saves to NVM. Inverted flips home direction and all moves.",
        "params": [
            { "parameter": "polarity", "type": "string", "enum": ["normal", "inverted"], "help": "normal = standard direction, inverted = all motions and home reversed" }
        ],
        "returns": ["done", "error"]
    },
    "home_on_boot": {
        "device": "fillhead",
        "target": "device",
        "description": "Sets whether the press should automatically home on startup and saves to NVM.",
        "params": [
            { "parameter": "enabled", "type": "string", "enum": ["true", "false"], "help": "true = auto-home on boot, false = skip homing on boot" }
        ],
        "returns": ["done", "error"]
    },
    "set_press_threshold": {
        "device": "fillhead",
        "target": "device",
        "description": "Sets the force threshold for energy/startpoint recording and saves to NVM. When force exceeds this threshold, the startpoint is recorded and energy integration begins.",
        "params": [
            { "parameter": "threshold", "unit": "kg", "type": "float", "help": "Force threshold in kg (0.1 to 50.0). Default is 2.0 kg." }
        ],
        "returns": ["done", "error"]
    },
    "home": {
        "device": "fillhead",
        "target": "device",
        "description": "Homes the press axis to its zero position.",
        "params": [],
        "returns": ["done", "error"]
    },
    "move_abs": {
        "device": "fillhead",
        "target": "device",
        "description": "Moves the press to an absolute position with speed and force limits.",
        "params": [
            { "parameter": "position", "unit": "mm", "type": "float" },
            { "parameter": "speed", "unit": "mm/s", "type": "float" },
            { "parameter": "force", "unit": "kg", "type": "float", "help": "In motor_torque mode: 50-2000 kg. In load_cell mode: 0.2-1000 kg." },
            { "parameter": "force_action", "type": "string", "enum": ["retract", "hold", "skip", "abort"], "optional": true, "default": "hold", "help": "Action when force limit reached: retract (retracts to retract position on ANY completion and returns done), hold (stops and waits), skip (ignores limit), abort (retracts ONLY if force limit hit, throws error to halt script)" }
        ],
        "returns": ["done", "error"]
    },
    "move_inc": {
        "device": "fillhead",
        "target": "device",
        "description": "Moves the press by a relative distance with speed and force limits.",
        "params": [
            { "parameter": "distance", "unit": "mm", "type": "float" },
            { "parameter": "speed", "unit": "mm/s", "type": "float" },
            { "parameter": "force", "unit": "kg", "type": "float", "help": "In motor_torque mode: 50-2000 kg. In load_cell mode: 0.2-1000 kg." },
            { "parameter": "force_action", "type": "string", "enum": ["retract", "hold", "skip"], "optional": true, "default": "hold" }
        ],
        "returns": ["done", "error"]
    },
    "set_retract": {
        "device": "fillhead",
        "target": "device",
        "description": "Sets the retract position for the press and saves to NVM.",
        "params": [
            { "parameter": "position", "unit": "mm", "type": "float" },
            { "parameter": "speed", "unit": "mm/s", "type": "float", "optional": true, "default": 25.0, "help": "Optional retract speed to store for future retract commands." }
        ],
        "returns": ["done", "error"]
    },
    "retract": {
        "device": "fillhead",
        "target": "device",
        "description": "Moves the press to the preset retract position with optional speed.",
        "params": [
            { "parameter": "speed", "unit": "mm/s", "type": "float", "optional": true, "default": 25.0 }
        ],
        "returns": ["done", "error"]
    },
